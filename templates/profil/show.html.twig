{% extends 'base.html.twig' %}

{% block title %}LA KAVASEB : Profil utilisateur{% endblock %}

{% block body %}

    <h1>Profil utilisateur</h1>
    <table class="table">
        <tbody>
            <tr>
                <th>Nom</th>
                <td>{{ utilisateur.nom }}</td>
            </tr>
            <tr>
                <th>Prénom</th>
                <td>{{ utilisateur.prenom }}</td>
            </tr>
            <tr>
                <th>Pseudonyme</th>
                <td>{{ utilisateur.pseudonyme }}</td>
            </tr>
            <tr>
                <th>E-Mail</th>
                <td>{{ utilisateur.email }}</td>
            </tr>
            <tr>
                <th>Téléphone</th>
                <td>{{ utilisateur.telephone }}</td>
            </tr>
            <tr>
                <th>Adresse</th>
                <td>{{ utilisateur.adresse }}</td>
            </tr>
            <tr>
                <th>Code postal</th>
                <td>{{ utilisateur.codePostal }}</td>
            </tr>
            <tr>
                <th>Ville</th>
                <td>{{ utilisateur.ville }}</td>
            </tr>
            <tr>
                <th>Pays</th>
                <td>{{ utilisateur.pays }}</td>
            </tr>
        </tbody>
    </table>
    <a href="{{ path('profil_edit') }}">Modifier</a>

{% endblock %}